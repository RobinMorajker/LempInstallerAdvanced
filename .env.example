# ── MariaDB ────────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=changeme_root
DB_NAME=mydb
DB_USER=myuser
DB_PASSWORD=changeme_user
# Password given to each auto-provisioned per-app database user
DB_APP_PASSWORD=changeme_app

# ── Nginx Proxy Manager ────────────────────────────────────────────────────────
NPM_EMAIL=admin@example.com
NPM_PASSWORD=changeme_npm

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New
# Homepage URL:            http://<PI-IP>:3000
# Authorization callback:  http://<PI-IP>:3000/auth/github/callback
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# ── Session ────────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# ── Deploy Engine ─────────────────────────────────────────────────────────────
PORT=3000
APPS_DIR=/var/www/apps
DOCKER_NETWORK=lemp_net
PHP_IMAGE=lemp-php-custom
CONTAINER_MEMORY=536870912
CONTAINER_NANOCPUS=500000000
