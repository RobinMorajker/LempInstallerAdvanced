{
  "name": "lemp-deploy-engine",
  "version": "1.0.0",
  "description": "Production-grade one-click deploy engine for LEMP stack on Raspberry Pi",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --ignore apps/ --ignore .sessions/ --ignore '*.db' src/server.js"
  },
  "nodemonConfig": {
    "ignore": ["apps/", ".sessions/", "*.db", "*.db-shm", "*.db-wal"]
  },
  "dependencies": {
    "axios": "^1.7.2",
    "connect-sqlite3": "^0.9.16",
    "dockerode": "^4.0.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "mysql2": "^3.9.7",
    "simple-git": "^3.25.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}
